generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model GameSave {
  id        String   @id @default(cuid())
  name      String
  seed      Int
  settings  String   @default("{}") // JSON: GalaxyGenConfig
  state     String   @default("{}") // JSON: serialized GameState
  tick      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
